generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Users & Auth ─────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  password        String
  role            String    @default("PATIENT")
  phone           String?
  avatar          String?
  clinicId        String?
  clinic          Clinic?   @relation(fields: [clinicId], references: [id])
  resetToken      String?
  resetTokenExpiry DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  patients      Patient[] @relation("PatientUser")
  doctorProfile Doctor?   @relation("DoctorUser")
  appointments  Appointment[] @relation("AppointmentUser")
  auditLogs     AuditLog[]
  notifications Notification[]

  @@index([email])
  @@index([role])
}

// ─── Clinics ──────────────────────────────────────────────────

model Clinic {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  email     String?
  logo      String?
  timezone  String   @default("UTC")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  doctors   Doctor[]
  patients  Patient[]
  treatments Treatment[]
  products  Product[]

  @@index([name])
}

// ─── Doctors ──────────────────────────────────────────────────

model Doctor {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation("DoctorUser", fields: [userId], references: [id])
  specialty String?
  licenseNo String?
  clinicId  String?
  clinic    Clinic?  @relation(fields: [clinicId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  treatments    Treatment[]
  appointments  Appointment[]
  doctorNotes   DoctorNote[]
  injectionMappings InjectionMapping[]

  @@index([userId])
}

// ─── Patients ─────────────────────────────────────────────────

model Patient {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation("PatientUser", fields: [userId], references: [id])
  clinicId        String?
  clinic          Clinic?  @relation(fields: [clinicId], references: [id])
  firstName       String
  lastName        String
  email           String?
  phone           String?
  dateOfBirth     DateTime?
  gender          String?
  address         String?
  medicalHistory  String?
  allergies       String?
  medications     String?
  emergencyContact String?
  consentGiven    Boolean  @default(false)
  consentDate     DateTime?
  pinHash         String?
  pinSetAt        DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  treatments      Treatment[]
  checkIns        RecoveryCheckIn[]
  photos          PatientPhoto[]
  appointments    Appointment[]
  surveys         Survey[]
  reviews         Review[]
  consentRecords  ConsentRecord[]
  complications   ComplicationRecord[]
  clinicalNotes   ClinicalNote[]
  silenceRiskLogs SilenceRiskLog[]

  @@index([email])
  @@index([phone])
  @@index([clinicId])
}

// ─── Products ─────────────────────────────────────────────────

model Product {
  id            String   @id @default(cuid())
  name          String
  category      String
  manufacturer  String?
  description   String?
  clinicId      String?
  clinic        Clinic?  @relation(fields: [clinicId], references: [id])
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  batches       ProductBatch[]
  injectionMappings InjectionMapping[]
  treatments    Treatment[]

  @@index([name])
  @@index([category])
}

// ─── Product Batches ──────────────────────────────────────────

model ProductBatch {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  batchNumber   String
  expiryDate    DateTime
  quantity      Int?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  injectionMappings InjectionMapping[]

  @@unique([productId, batchNumber])
  @@index([batchNumber])
  @@index([expiryDate])
}

// ─── Treatment Protocols ──────────────────────────────────────

model TreatmentProtocol {
  id              String   @id @default(cuid())
  procedureType   String   @unique
  category        String
  substance       String?
  typicalVolumes  String?
  recoveryTimeline String
  normalSymptoms  String
  warningSigns    String
  emergencySigns  String
  followUpSchedule String
  contraindications String
  postProcedureInstructions String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([procedureType])
  @@index([category])
}

// ─── Treatments ───────────────────────────────────────────────

model Treatment {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  doctorId        String?
  doctor          Doctor?  @relation(fields: [doctorId], references: [id])
  clinicId        String?
  clinic          Clinic?  @relation(fields: [clinicId], references: [id])
  type            String
  productName     String?
  productId       String?
  product         Product? @relation(fields: [productId], references: [id])
  units           Float?
  volume          Float?
  injectionAreas  String   @default("[]")
  treatmentDate   DateTime @default(now())
  notes           String?
  aftercareNotes  String?
  status          String   @default("COMPLETED")
  nextReviewDate  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  checkIns        RecoveryCheckIn[]
  doctorNotes     DoctorNote[]
  injectionMappings InjectionMapping[]
  complications   ComplicationRecord[]
  clinicalNotes   ClinicalNote[]
  clinicalDocuments ClinicalDocument[]

  @@index([patientId])
  @@index([treatmentDate])
  @@index([type])
}

// ─── Injection Mapping ────────────────────────────────────────

model InjectionMapping {
  id              String   @id @default(cuid())
  treatmentId     String
  treatment       Treatment @relation(fields: [treatmentId], references: [id])
  doctorId        String?
  doctor          Doctor?  @relation(fields: [doctorId], references: [id])
  area            String
  subArea         String?
  units           Float?
  volume          Float?
  productId       String?
  product         Product? @relation(fields: [productId], references: [id])
  batchId         String?
  batch           ProductBatch? @relation(fields: [batchId], references: [id])
  technique       String?
  needleCannula   String?
  depth           String?
  aspiration      String?
  notes           String?
  createdAt       DateTime @default(now())

  @@index([treatmentId])
  @@index([area])
  @@index([productId])
}

// ─── Recovery Check-ins ───────────────────────────────────────

model RecoveryCheckIn {
  id              String   @id @default(cuid())
  treatmentId     String
  treatment       Treatment @relation(fields: [treatmentId], references: [id])
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  dayNumber       Int
  scheduledDate   DateTime
  completedDate   DateTime?
  status          String   @default("PENDING")
  patientMessage  String?
  aiResponse      String?
  riskLevel       String   @default("GREEN")
  symptoms        String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  photos          PatientPhoto[]
  aiAnalyses      AIAnalysis[]
  doctorNotes     DoctorNote[]
  silenceRiskLogs SilenceRiskLog[]

  @@index([treatmentId])
  @@index([patientId])
  @@index([scheduledDate])
  @@index([status])
  @@index([riskLevel])
}

// ─── Patient Photos ───────────────────────────────────────────

model PatientPhoto {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  checkInId       String?
  checkIn         RecoveryCheckIn? @relation(fields: [checkInId], references: [id])
  imageUrl        String
  thumbnailUrl    String?
  uploadDate      DateTime @default(now())
  qualityScore    Float?
  metadata        String?
  timepoint       String?
  source          String   @default("PORTAL") // PORTAL, WHATSAPP, CLINIC
  whatsappMessageId String?
  createdAt       DateTime @default(now())

  aiAnalyses      AIAnalysis[]

  @@index([patientId])
  @@index([checkInId])
  @@index([source])
}

// ─── AI Analysis ──────────────────────────────────────────────

model AIAnalysis {
  id              String   @id @default(cuid())
  photoId         String
  photo           PatientPhoto @relation(fields: [photoId], references: [id])
  checkInId       String?
  checkIn         RecoveryCheckIn? @relation(fields: [checkInId], references: [id])
  analysisDate    DateTime @default(now())
  swellingScore   Float    @default(0)
  bruisingScore   Float    @default(0)
  rednessScore    Float    @default(0)
  asymmetryScore  Float    @default(0)
  noduleScore     Float    @default(0)
  vascularityScore Float   @default(0)
  overallScore    Float    @default(0)
  confidenceScore Float    @default(0)
  riskLevel       String   @default("GREEN")
  clinicalFeatures String   @default("{}")
  status          String   @default("PENDING")
  findings        String   @default("[]")
  recommendations String   @default("[]")
  clinicalSummary String?
  recommendedAction String?
  rawResponse     String?
  doctorOverride  Boolean  @default(false)
  doctorNotes     String?
  overrideRiskLevel String?
  // Feature 2: Photo-Based Symptom Trend Tracking
  trendDirection  String?  // IMPROVING, STABLE, WORSENING
  trendDetails    String?  // JSON: {metric, previousScore, currentScore, changePercent}
  // Feature 4: AI Explainability
  rationale       String?  // Structured clinical rationale for the classification
  confidenceFactors String? // JSON: [{factor, weight, impact}]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([photoId])
  @@index([checkInId])
  @@index([riskLevel])
  @@index([status])
}

// ─── Consent Records ──────────────────────────────────────────

model ConsentRecord {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  consentType     String
  version         String
  status          String   @default("ACTIVE")
  givenDate       DateTime @default(now())
  withdrawnDate   DateTime?
  documentUrl     String?
  metadata        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([patientId])
  @@index([consentType])
  @@index([status])
}

// ─── Complication Records ─────────────────────────────────────

model ComplicationRecord {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  treatmentId     String?
  treatment       Treatment? @relation(fields: [treatmentId], references: [id])
  complicationType String
  description     String?
  severity        String
  onsetDate       DateTime
  resolutionDate  DateTime?
  treatmentGiven  String?
  outcome         String?
  reportedToRegulatory Boolean @default(false)
  batchNumber     String?
  productUsed     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([patientId])
  @@index([treatmentId])
  @@index([complicationType])
  @@index([severity])
}

// ─── Clinical Notes ───────────────────────────────────────────

model ClinicalNote {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  doctorId        String?
  treatmentId     String?
  treatment       Treatment? @relation(fields: [treatmentId], references: [id])
  checkInId       String?
  noteType        String
  content         String
  isAiGenerated   Boolean  @default(false)
  isPrivate       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([patientId])
  @@index([noteType])
  @@index([createdAt])
}

// ─── Clinical Documents ───────────────────────────────────────

model ClinicalDocument {
  id              String   @id @default(cuid())
  treatmentId     String
  treatment       Treatment @relation(fields: [treatmentId], references: [id])
  documentType    String
  content         String
  generatedBy     String   @default("AI")
  doctorApproved  Boolean  @default(false)
  doctorId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([treatmentId])
  @@index([documentType])
}

// ─── Doctor Notes ─────────────────────────────────────────────

model DoctorNote {
  id              String   @id @default(cuid())
  doctorId        String
  doctor          Doctor   @relation(fields: [doctorId], references: [id])
  treatmentId     String?
  treatment       Treatment? @relation(fields: [treatmentId], references: [id])
  checkInId       String?
  checkIn         RecoveryCheckIn? @relation(fields: [checkInId], references: [id])
  content         String
  isPrivate       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([doctorId])
  @@index([treatmentId])
}

// ─── Appointments ─────────────────────────────────────────────

model Appointment {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  doctorId        String?
  doctor          Doctor?  @relation(fields: [doctorId], references: [id])
  userId          String?
  user            User?    @relation("AppointmentUser", fields: [userId], references: [id])
  clinicId        String?
  appointmentDate DateTime
  duration        Int      @default(30)
  type            String   @default("CONSULTATION")
  status          String   @default("SCHEDULED")
  notes           String?
  reminderSent    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([patientId])
  @@index([appointmentDate])
  @@index([status])
}

// ─── Notifications ────────────────────────────────────────────

model Notification {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  title           String
  message         String
  type            String
  channel         String
  sentAt          DateTime?
  readAt          DateTime?
  isRead          Boolean  @default(false)
  metadata        String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([isRead])
}

// ─── Surveys ──────────────────────────────────────────────────

model Survey {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  treatmentId     String?
  type            String
  responses       String   @default("{}")
  completedAt     DateTime?
  createdAt       DateTime @default(now())

  @@index([patientId])
  @@index([type])
}

// ─── Reviews ──────────────────────────────────────────────────

model Review {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  rating          Int
  comment         String?
  isPublic        Boolean  @default(false)
  googleReviewUrl String?
  createdAt       DateTime @default(now())

  @@index([patientId])
  @@index([rating])
}

// ─── Audit Logs ───────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String?
  oldValues   String?
  newValues   String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

// ─── Silence Risk Log (Feature 1) ────────────────────────────

model SilenceRiskLog {
  id              String   @id @default(cuid())
  checkInId       String
  checkIn         RecoveryCheckIn @relation(fields: [checkInId], references: [id])
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  treatmentType   String
  missedDayNumber Int
  scheduledDate   DateTime
  detectedAt      DateTime @default(now())
  riskScore       Float    @default(0) // Weighted risk: higher = more urgent
  escalationLevel String   @default("LOW") // LOW, MEDIUM, HIGH, CRITICAL
  resolvedAt      DateTime?
  resolvedBy      String?
  resolutionNotes String?
  createdAt       DateTime @default(now())

  @@index([checkInId])
  @@index([patientId])
  @@index([escalationLevel])
  @@index([detectedAt])
}
